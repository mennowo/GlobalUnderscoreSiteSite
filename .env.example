# Copy to .env and fill in
PORT=3010
BASE_URL=http://localhost:5173

# Long random string (openssl rand -hex 32). REQUIRED — the server will refuse to
# start without it. Used for cookie signing and captcha HMAC.
SESSION_SECRET=replace-me-with-a-long-random-string

# --- Local auth (username + password) -----------------------------------------
# First admin is bootstrapped from these two vars. Changing BOOTSTRAP_ADMIN_PASSWORD
# and restarting resets the first admin's password. UI-changed passwords persist across
# restarts as long as BOOTSTRAP_ADMIN_PASSWORD itself is unchanged.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-12-chars-min

# Set LOCAL_AUTH_DISABLED=1 to turn off local auth even when SESSION_SECRET is set.
#LOCAL_AUTH_DISABLED=1

# --- OIDC (optional; can run alongside local auth) ----------------------------
#OIDC_ISSUER=https://your-tenant.auth0.com
#OIDC_CLIENT_ID=your-client-id
#OIDC_CLIENT_SECRET=your-client-secret

# Comma-separated emails allowed to edit the site (OIDC users only).
#ADMIN_EMAILS=admin@example.com
